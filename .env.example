# ── HuggingFace ───────────────────────────────────────────────────────────────
# Clé API HuggingFace (créer sur https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle à utiliser (doit supporter le function calling)
# Options recommandées :
#   Qwen/Qwen2.5-7B-Instruct    (défaut, gratuit, excellent tool use)
#   Qwen/Qwen2.5-72B-Instruct   (plus puissant, gratuit, plus lent)
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8080/sse

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
