# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# URL of the Ollama server (set automatically by Docker Compose)
OLLAMA_BASE_URL=http://ollama:11434

# Model to use — must be pulled by ollama-init first
# Options: llama3.2:1b | llama3.2 | llama3.1:8b | mistral | qwen2.5:7b
OLLAMA_MODEL=llama3.2:1b

# ── MCP Server ────────────────────────────────────────────────────────────────
# SSE endpoint of the FastMCP RAG server (set automatically by Docker Compose)
MCP_SERVER_URL=http://mcp-server:8080/sse

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Hostname and port of the ChromaDB HTTP server (set automatically by Docker Compose)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
